#!/usr/bin/env bash
#======================================================================
# SANDRA SENTINEL - Compilador Unificado del Workspace Rust
# Autor: Odin / Sandra Fábrica de Software
# Descripción: Compila, testea y empaqueta todo el workspace Sentinel
#              (core, sandra-conciliate, reconciler, cli) en un solo punto de entrada.
# Uso: ./sandra-sentinel [comando] [opciones]
#======================================================================

set -euo pipefail

#---------------------------------------------------------------------
# CONFIGURACIÓN Y VARIABLES GLOBALES
#---------------------------------------------------------------------
readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_VERSION="1.0.0"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colores
RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; NC=''

setup_colors() {
    if [[ -t 1 ]]; then
        local ncolors
        ncolors=$(tput colors 2>/dev/null || echo 0)
        if [[ $ncolors -ge 8 ]]; then
            RED=$'\033[0;31m'
            GREEN=$'\033[0;32m'
            YELLOW=$'\033[1;33m'
            BLUE=$'\033[0;34m'
            CYAN=$'\033[0;36m'
            BOLD=$'\033[1m'
            NC=$'\033[0m'
        fi
    fi
}
setup_colors

# Valores por defecto
COMMAND=""
PROFILE="release"
TARGET=""
VERBOSE=false
SKIP_TESTS=false
CLEAN=false
INSTALL=false
DIST_DIR="dist"

# Bins del workspace
BINS=("sandra-sentinel" "sandra-reconciler" "sandra-conciliate")

#---------------------------------------------------------------------
# UTILIDADES DE LOG
#---------------------------------------------------------------------
log_info()  { echo "${BLUE}[INFO]${NC}  $*"; }
log_ok()    { echo "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo "${RED}[ERROR]${NC} $*" >&2; }
log_step()  { echo "${CYAN}${BOLD}==>${NC} $*"; }

#---------------------------------------------------------------------
# AYUDA
#---------------------------------------------------------------------
show_help() {
    cat <<EOF
${BOLD}Sandra Sentinel Workspace Compiler v${SCRIPT_VERSION}${NC}

Uso: ${SCRIPT_NAME} <comando> [opciones]

Comandos:
  build           Compila todo el workspace (por defecto: --release)
  test            Ejecuta tests de todo el workspace
  check           Ejecuta cargo check (rápido, sin artefactos)
  clean           Limpia artefactos de compilación (cargo clean)
  install         Compila en release e instala bins en /usr/local/bin
  dist            Genera tarball release en ./dist/

Opciones:
  -d, --debug     Compila en perfil debug (sin optimizaciones)
  -t, --target    Target de compilación cross (ej: x86_64-unknown-linux-gnu)
  -s, --skip-tests  Omite ejecución de tests durante build/dist
  -v, --verbose   Salida verbose de cargo
  -h, --help      Muestra esta ayuda

Ejemplos:
  ./sandra-sentinel build           # Release build rápido
  ./sandra-sentinel build --debug   # Debug build
  ./sandra-sentinel test            # Tests completos
  ./sandra-sentinel dist            # Release + tarball en dist/
  ./sandra-sentinel install         # Instala localmente
EOF
}

#---------------------------------------------------------------------
# PARSEO DE ARGUMENTOS
#---------------------------------------------------------------------
parse_args() {
    if [[ $# -eq 0 ]]; then
        COMMAND="build"
        return
    fi

    COMMAND="$1"
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -d|--debug)
                PROFILE="dev"
                ;;
            -t|--target)
                TARGET="$2"
                shift
                ;;
            -s|--skip-tests)
                SKIP_TESTS=true
                ;;
            -v|--verbose)
                VERBOSE=true
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                log_error "Opción desconocida: $1"
                show_help
                exit 1
                ;;
        esac
        shift
    done
}

#---------------------------------------------------------------------
# DETECTAR TARGET POR HOST
#---------------------------------------------------------------------
host_target() {
    local arch
    arch=$(rustc -vV | sed -n 's|host: ||p')
    echo "$arch"
}

#---------------------------------------------------------------------
# CARGO FLAGS COMUNES
#---------------------------------------------------------------------
cargo_common_flags() {
    local flags=""
    [[ "$VERBOSE" == true ]] && flags="$flags --verbose"
    [[ -n "$TARGET" ]] && flags="$flags --target $TARGET"
    echo "$flags"
}

#---------------------------------------------------------------------
# COMANDO: CHECK
#---------------------------------------------------------------------
cmd_check() {
    log_step "Chequeando workspace..."
    local flags
    flags=$(cargo_common_flags)
    # shellcheck disable=SC2086
    cargo check --workspace $flags
    log_ok "Check completado"
}

#---------------------------------------------------------------------
# COMANDO: TEST
#---------------------------------------------------------------------
cmd_test() {
    log_step "Ejecutando tests del workspace..."
    local flags
    flags=$(cargo_common_flags)
    # shellcheck disable=SC2086
    cargo test --workspace $flags
    log_ok "Tests completados"
}

#---------------------------------------------------------------------
# COMANDO: BUILD
#---------------------------------------------------------------------
cmd_build() {
    log_step "Compilando workspace Sentinel..."

    if [[ "$SKIP_TESTS" != true ]]; then
        cmd_test
        echo
    fi

    local flags
    flags=$(cargo_common_flags)

    if [[ "$PROFILE" == "release" ]]; then
        flags="$flags --release"
        log_info "Perfil: RELEASE (optimizado)"
    else
        log_info "Perfil: DEBUG"
    fi

    log_info "Bins a compilar: ${BINS[*]}"
    [[ -n "$TARGET" ]] && log_info "Target: $TARGET"

    # Compilar workspace completo
    # shellcheck disable=SC2086
    cargo build --workspace $flags

    # Reportar artefactos
    local target_dir
    if [[ -n "$TARGET" ]]; then
        target_dir="target/${TARGET}/${PROFILE}"
    else
        target_dir="target/${PROFILE}"
    fi

    echo
    log_ok "Compilación exitosa"
    for bin in "${BINS[@]}"; do
        local bin_path="${SCRIPT_DIR}/${target_dir}/${bin}"
        if [[ -f "$bin_path" ]]; then
            local size
            size=$(du -sh "$bin_path" | cut -f1)
            log_ok "  ${bin}  →  ${target_dir}/${bin}  (${size})"
        else
            log_warn "  ${bin} no encontrado en ${target_dir}"
        fi
    done
}

#---------------------------------------------------------------------
# COMANDO: CLEAN
#---------------------------------------------------------------------
cmd_clean() {
    log_step "Limpiando artefactos..."
    cargo clean
    rm -rf "${SCRIPT_DIR}/${DIST_DIR}"
    log_ok "Limpieza completada"
}

#---------------------------------------------------------------------
# COMANDO: INSTALL
#---------------------------------------------------------------------
cmd_install() {
    PROFILE="release"
    cmd_build

    local target_dir="target/release"
    local install_prefix="${INSTALL_PREFIX:-/usr/local/bin}"

    log_step "Instalando bins en ${install_prefix}..."
    for bin in "${BINS[@]}"; do
        local src="${SCRIPT_DIR}/${target_dir}/${bin}"
        if [[ -f "$src" ]]; then
            cp "$src" "${install_prefix}/${bin}"
            chmod +x "${install_prefix}/${bin}"
            log_ok "  ${bin} instalado"
        else
            log_error "  ${bin} no encontrado"
        fi
    done
    log_ok "Instalación completada"
}

#---------------------------------------------------------------------
# COMANDO: DIST
#---------------------------------------------------------------------
cmd_dist() {
    PROFILE="release"
    cmd_build

    local target_dir="target/release"
    local host
    host=$(host_target)
    local version
    version=$(grep '^version' "${SCRIPT_DIR}/cli/Cargo.toml" | head -1 | sed 's/.*"\(.*\)".*/\1/')
    local dist_name="sandra-sentinel-${version}-${host}"
    local dist_path="${SCRIPT_DIR}/${DIST_DIR}/${dist_name}"

    log_step "Generando distribución: ${dist_name}.tar.gz ..."
    mkdir -p "$dist_path"

    # Copiar bins
    for bin in "${BINS[@]}"; do
        local src="${SCRIPT_DIR}/${target_dir}/${bin}"
        [[ -f "$src" ]] && cp "$src" "${dist_path}/"
    done

    # Metadatos
    cat > "${dist_path}/VERSION" <<EOF
Sandra Sentinel v${version}
Host: ${host}
Build Date: $(date -u +%Y-%m-%dT%H:%M:%SZ)
Git Commit: $(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || echo "N/A")
Bins: ${BINS[*]}
EOF

    # Empaquetar
    mkdir -p "${SCRIPT_DIR}/${DIST_DIR}"
    tar -czf "${SCRIPT_DIR}/${DIST_DIR}/${dist_name}.tar.gz" -C "${SCRIPT_DIR}/${DIST_DIR}" "$dist_name"
    rm -rf "$dist_path"

    local size
    size=$(du -sh "${SCRIPT_DIR}/${DIST_DIR}/${dist_name}.tar.gz" | cut -f1)
    log_ok "Distribución generada: ${DIST_DIR}/${dist_name}.tar.gz (${size})"
}

#---------------------------------------------------------------------
# MAIN
#---------------------------------------------------------------------
main() {
    parse_args "$@"

    # Verificar que estamos en el directorio correcto
    if [[ ! -f "${SCRIPT_DIR}/Cargo.toml" ]]; then
        log_error "No se encontró Cargo.toml en ${SCRIPT_DIR}"
        exit 1
    fi

    cd "$SCRIPT_DIR"

    case "$COMMAND" in
        build)
            cmd_build
            ;;
        test)
            cmd_test
            ;;
        check)
            cmd_check
            ;;
            clean)
            cmd_clean
            ;;
        install)
            cmd_install
            ;;
        dist)
            cmd_dist
            ;;
        help|h|-h|--help)
            show_help
            ;;
        *)
            log_error "Comando desconocido: $COMMAND"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
