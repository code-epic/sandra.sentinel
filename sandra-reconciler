#!/usr/bin/env bash
#======================================================================
# SANDRA RECONCILER - Script de Ejecución y Compilación
# Autor: Odin / Sandra Fábrica de Software
# Descripción: Wrapper que compila (si es necesario) y ejecuta el
#              reconciler de alta velocidad CSV vs gRPC.
# Uso: ./sandra-reconciler [comando] [opciones]
#======================================================================

set -euo pipefail

#---------------------------------------------------------------------
# CONFIGURACIÓN
#---------------------------------------------------------------------
readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly BIN_NAME="sandra-reconciler"
readonly RELEASE_BIN="${SCRIPT_DIR}/target/release/${BIN_NAME}"
readonly DEBUG_BIN="${SCRIPT_DIR}/target/debug/${BIN_NAME}"

# Colores
RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; NC=''
setup_colors() {
    if [[ -t 1 ]]; then
        local ncolors
        ncolors=$(tput colors 2>/dev/null || echo 0)
        if [[ $ncolors -ge 8 ]]; then
            RED=$'\033[0;31m'
            GREEN=$'\033[0;32m'
            YELLOW=$'\033[1;33m'
            BLUE=$'\033[0;34m'
            CYAN=$'\033[0;36m'
            BOLD=$'\033[1m'
            NC=$'\033[0m'
        fi
    fi
}
setup_colors

log_info()  { echo "${BLUE}[INFO]${NC}  $*"; }
log_ok()    { echo "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo "${YELLOW}[WARN]${NC}  $*"; }
log_error() { echo "${RED}[ERROR]${NC} $*" >&2; }
log_step()  { echo "${CYAN}${BOLD}==>${NC} $*"; }

#---------------------------------------------------------------------
# AYUDA
#---------------------------------------------------------------------
show_help() {
    cat <<EOF
${BOLD}Sandra Reconciler Runner${NC}

Uso: ${SCRIPT_NAME} <comando> [opciones]

Comandos:
  run             Ejecuta el reconciler (compila automáticamente si falta)
  build           Compila el reconciler en release
  build-debug     Compila el reconciler en debug
  test            Ejecuta tests del crate reconciler
  check           Ejecuta cargo check sobre reconciler
  example         Ejecuta contra los archivos de ejemplo (CSV + mapping)
  generate-mapping  Genera mapping_existente.json válido en el directorio actual
  clean           Limpia artefactos del reconciler

Opciones de ejecución (comando 'run'):
  --csv <path>          Ruta al CSV (por defecto: reconciler/examples/nomina_real.csv)
  --mapping <path>      Ruta al mapping JSON (opcional; si no se provee, detecta automáticamente)
  --grpc <url>          URL del servicio gRPC (por defecto: http://localhost:50051)
  --function <name>     Nombre de la función gRPC (por defecto: IPSFA_CBeneficiarios)
  --parametros <val>    Parámetros de la función (por defecto: "%")
  --output <dir>        Directorio de salida (por defecto: ./reconcile-out)
  --debug               Activa modo diagnóstico de campos
  --quiet               Suprime salida progreso

Ejemplos:
  ./sandra-reconciler run                       # Ejecuta con defaults (detección automática)
  ./sandra-reconciler run --csv data.csv --mapping map.json
  ./sandra-reconciler example                   # Corre con datos de ejemplo
  ./sandra-reconciler generate-mapping          # Crea mapping_existente.json
  ./sandra-reconciler build                     # Solo compila
  ./sandra-reconciler check                     # Check rápido
EOF
}

#---------------------------------------------------------------------
# PARSEO
#---------------------------------------------------------------------
COMMAND=""
CSV_PATH="${SCRIPT_DIR}/reconciler/examples/nomina_real.csv"
MAPPING_PATH="${SCRIPT_DIR}/reconciler/examples/mapping_existente.json"
GRPC_URL="http://localhost:50051"
GRPC_FUNCTION="IPSFA_CBeneficiarios"
GRPC_PARAMS="\"%\""
OUTPUT_DIR="./reconcile-out"
DEBUG_FLAG=false
QUIET_FLAG=false

parse_args() {
    if [[ $# -eq 0 ]]; then
        COMMAND="run"
        return
    fi

    COMMAND="$1"
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --csv)
                CSV_PATH="$2"
                shift
                ;;
            --mapping)
                MAPPING_PATH="$2"
                shift
                ;;
            --grpc)
                GRPC_URL="$2"
                shift
                ;;
            --function)
                GRPC_FUNCTION="$2"
                shift
                ;;
            --parametros)
                GRPC_PARAMS="$2"
                shift
                ;;
            --output)
                OUTPUT_DIR="$2"
                shift
                ;;
            --debug)
                DEBUG_FLAG=true
                ;;
            --quiet)
                QUIET_FLAG=true
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                log_error "Opción desconocida: $1"
                show_help
                exit 1
                ;;
        esac
        shift
    done
}

#---------------------------------------------------------------------
# BUILD
#---------------------------------------------------------------------
ensure_release() {
    if [[ ! -f "$RELEASE_BIN" ]]; then
        log_step "Compilando ${BIN_NAME} (release)..."
        cd "$SCRIPT_DIR"
        cargo build --release --package reconciler
        log_ok "Compilación completada: ${RELEASE_BIN}"
    fi
}

ensure_debug() {
    if [[ ! -f "$DEBUG_BIN" ]]; then
        log_step "Compilando ${BIN_NAME} (debug)..."
        cd "$SCRIPT_DIR"
        cargo build --package reconciler
        log_ok "Compilación completada: ${DEBUG_BIN}"
    fi
}

cmd_build() {
    log_step "Compilando reconciler en release..."
    cd "$SCRIPT_DIR"
    cargo build --release --package reconciler
    log_ok "Binario generado: target/release/${BIN_NAME}"
}

cmd_build_debug() {
    log_step "Compilando reconciler en debug..."
    cd "$SCRIPT_DIR"
    cargo build --package reconciler
    log_ok "Binario generado: target/debug/${BIN_NAME}"
}

cmd_test() {
    log_step "Ejecutando tests de reconciler..."
    cd "$SCRIPT_DIR"
    cargo test --package reconciler
    log_ok "Tests completados"
}

cmd_check() {
    log_step "Chequeando reconciler..."
    cd "$SCRIPT_DIR"
    cargo check --package reconciler
    log_ok "Check completado"
}

cmd_generate_mapping() {
    local out_file="${PWD}/mapping_existente.json"
    log_step "Generando mapping_existente.json en ${out_file}..."
    cat > "$out_file" <<'JSON'
[
  {
    "field_name": "grado",
    "csv_column": "grado",
    "grpc_path": ["grado_id"],
    "strategy": { "type": "Exact" }
  },
  {
    "field_name": "n_hijos",
    "csv_column": "n_hijos",
    "grpc_path": ["n_hijos"],
    "strategy": { "type": "Numeric", "epsilon": 0.0 }
  },
  {
    "field_name": "f_ingreso",
    "csv_column": "f_ingreso",
    "grpc_path": ["f_ingreso"],
    "strategy": { "type": "Date" }
  },
  {
    "field_name": "f_ult_ascenso",
    "csv_column": "f_ult_ascenso",
    "grpc_path": ["f_ult_ascenso"],
    "strategy": { "type": "Date" }
  },
  {
    "field_name": "st_profesion",
    "csv_column": "st_profesion",
    "grpc_path": ["st_profesion"],
    "strategy": { "type": "Exact" }
  },
  {
    "field_name": "anio_reconocido",
    "csv_column": "anio_reconocido",
    "grpc_path": ["anio_reconocido"],
    "strategy": { "type": "Numeric", "epsilon": 0.0 }
  },
  {
    "field_name": "mes_reconocido",
    "csv_column": "mes_reconocido",
    "grpc_path": ["mes_reconocido"],
    "strategy": { "type": "Numeric", "epsilon": 0.0 }
  },
  {
    "field_name": "dia_reconocido",
    "csv_column": "dia_reconocido",
    "grpc_path": ["dia_reconocido"],
    "strategy": { "type": "Numeric", "epsilon": 0.0 }
  }
]
JSON
    log_ok "Archivo generado: ${out_file}"
    log_info "Edítalo según los nombres reales de columnas de tu CSV y campos gRPC"
}

cmd_clean() {
    log_step "Limpiando artefactos..."
    cd "$SCRIPT_DIR"
    cargo clean --package reconciler 2>/dev/null || cargo clean
    rm -rf "$OUTPUT_DIR"
    log_ok "Limpieza completada"
}

#---------------------------------------------------------------------
# RUN
#---------------------------------------------------------------------
cmd_run() {
    ensure_release

    log_step "Ejecutando reconciler..."
    log_info "CSV:       ${CSV_PATH}"
    log_info "Mapping:   ${MAPPING_PATH}"
    log_info "gRPC:      ${GRPC_URL}"
    log_info "Función:   ${GRPC_FUNCTION}"
    log_info "Salida:    ${OUTPUT_DIR}"

    local args=()
    args+=("--csv-path" "$CSV_PATH")
    args+=("--field-mapping" "$MAPPING_PATH")
    args+=("--grpc-url" "$GRPC_URL")
    args+=("--grpc-function" "$GRPC_FUNCTION")
    args+=("--grpc-parametros" "$GRPC_PARAMS")
    args+=("--output-dir" "$OUTPUT_DIR")

    [[ "$DEBUG_FLAG" == true ]] && args+=("--debug")
    [[ "$QUIET_FLAG" == true ]] && args+=("--quiet")

    "${RELEASE_BIN}" "${args[@]}"
}

#---------------------------------------------------------------------
# EXAMPLE
#---------------------------------------------------------------------
cmd_example() {
    log_step "Ejecutando con datos de ejemplo..."

    if [[ ! -f "$CSV_PATH" ]]; then
        log_error "No se encontró el CSV de ejemplo: ${CSV_PATH}"
        exit 1
    fi
    if [[ ! -f "$MAPPING_PATH" ]]; then
        log_error "No se encontró el mapping de ejemplo: ${MAPPING_PATH}"
        exit 1
    fi

    log_warn "Modo ejemplo: no se requiere gRPC activo (procesará como huérfanos si no hay conexión)"
    echo

    DEBUG_FLAG=true
    cmd_run

    echo
    log_step "Resultados generados en: ${OUTPUT_DIR}/"
    ls -lh "${OUTPUT_DIR}/" 2>/dev/null || true
}

#---------------------------------------------------------------------
# MAIN
#---------------------------------------------------------------------
main() {
    parse_args "$@"

    case "$COMMAND" in
        run)
            cmd_run
            ;;
        build)
            cmd_build
            ;;
        build-debug)
            cmd_build_debug
            ;;
        test)
            cmd_test
            ;;
        check)
            cmd_check
            ;;
        example)
            cmd_example
            ;;
        generate-mapping)
            cmd_generate_mapping
            ;;
        clean)
            cmd_clean
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            log_error "Comando desconocido: $COMMAND"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
